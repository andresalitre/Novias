Items: {
	GatitoMenso: {
		DisplayName: Gatito Menso
		Tooltip: No quiere que lo lances... O eso dice
	}

	GatitoDePeluche: {
		DisplayName: Gatito De Peluche
		Tooltip:
			'''
			Un adorable gatito de peluche
			"A alguien le gustan mucho los gatitos".
			'''
	}

	PocionDeTsundere: {
		DisplayName: Poción de Tsundere
		Tooltip:
			'''
			Un fuerte amor intensifica tu fuerza
			Aumenta un 15% el daño y crítico cuerpo a cuerpo
			'''
	}

	RefrescoDeMelocoton: {
		DisplayName: Refresco De Melocotón
		Tooltip: Un exquisito refresco sabor melocotón
	}

	MedioRefrescoDeMelocoton: {
		DisplayName: Medio Refresco De Melocotón
		Tooltip:
			'''
			La mitad de un exquisito refresco sabor melocotón
			"A alguien le podría interesar un beso indirecto".
			'''
	}

	CañonDeLeche: {
		DisplayName: Cañón de Leche
		Tooltip: Hakari lo cargó con mucho cariño... y otras cosas
	}

	LecheHakariMunicion: {
		DisplayName: Leche Hakari
		Tooltip: Directamente traída de la granja. No preguntes de cuál.
	}

	PocionDeSeduccion: {
		DisplayName: Poción de Seducción
		Tooltip:
			'''
			Un amor abrasador recupera tus heridas
			Aumenta tu regeneración de vida
			'''
	}

	ElRomanceDeLaDiadema: {
		DisplayName: El Romance De La Diadema
		Tooltip: Imbuido mágicamente con el canto de una voz silenciosa.
	}

	TelefonoDeShizuka: {
		DisplayName: Teléfono De Shizuka
		Tooltip:
			'''
			¡Una tecnología de otro mundo! Al parecer no.
			"Shizuka estará muy feliz de poder hablar contigo."
			'''
	}

	PocionDeEcosDeAmor: {
		DisplayName: Poción de Ecos de Amor
		Tooltip:
			'''
			Un amor silencioso te hace sobrepasar tus límites mágicos
			Aumenta tu regeneración de maná y tu maná máximo
			'''
	}

	Familia: {
		DisplayName: Familia
		Tooltip: '''"La familia es primero".'''
	}

	PocionDeEficiencia: {
		DisplayName: Poción De Eficiencia
		Tooltip:
			'''
			Un amor eficiente aumenta tu eficacia, valga la madre
			Aumenta tu velocidad de movimiento, ataque y minería
			'''
	}

	Cutter: {
		DisplayName: Cutter
		Tooltip: Afilado, rápido, preciso y eficiente. También frío, como su dueña.
	}

	SuperPocionDeRecuperacion: {
		DisplayName: Super Poción De Recuperación
		Tooltip:
			'''
			La manera más eficiente de poder regresar a casa, claro, no la puedes usar solo.
			"Nano podrá estar tranquila."
			'''
	}
}

Buffs: {
	FuerzaDeTsundere: {
		DisplayName: Fuerza de Tsundere
		Description:
			'''
			Tu cuerpo se llena de energía tsundere
			Aumenta tu daño y crítico cuerpo a cuerpo
			'''
	}

	ImpulsoSeductor: {
		DisplayName: Impulso Seductor
		Description:
			'''
			Tu cuerpo empieza a calentarse
			Aumenta considerablemente tu regeneración de vida
			'''
	}

	ArmoniaMagica: {
		DisplayName: Armonía Mágica
		Description:
			'''
			Una hermosa voz fluye por tus venas
			Aumenta tus capacidades mágicas
			'''
	}

	Eficiencia: {
		DisplayName: Eficiencia
		Description:
			'''
			No hubiera sido eficiente pensar en una mejor descripción para este buff
			Aumenta la velocidad de todo
			'''
	}
}

